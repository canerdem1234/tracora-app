# ============================================
# TRACORA - Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyala: cp .env.local.example .env.local
# .env.local ASLA git'e commit edilmez
# ============================================

# Supabase (Public - Client tarafında da kullanılır)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__xxxxxxxxxxxxxxxxxxxxxx

# Supabase (Secret - SADECE sunucu tarafı, asla NEXT_PUBLIC_ ekleme)
SUPABASE_SERVICE_ROLE_KEY=sb_secret__xxxxxxxxxxxxxxxxxxxxxx

# OpenAI (Secret - SADECE sunucu tarafı)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://tracora.ai

# Stripe (İleride eklenecek)
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxx
